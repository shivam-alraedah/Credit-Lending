{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mal.ai/schemas/aecb.v1.json",
  "title": "AECB canonical report row (post-parse)",
  "type": "object",
  "required": ["emirates_id", "bureau_batch_id", "report_ts"],
  "properties": {
    "emirates_id": {
      "type": "string",
      "pattern": "^[0-9]{3}-[0-9]{4}-[0-9]{7}-[0-9]{1}$"
    },
    "bureau_batch_id": { "type": "string", "minLength": 1 },
    "report_ts": { "type": "string", "format": "date-time" },
    "bureau_score": { "type": ["integer", "null"], "minimum": 0, "maximum": 1000 },
    "delinquency_flags": { "type": ["object", "null"] }
  },
  "additionalProperties": true
}
